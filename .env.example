# Salin ke .env dan isi sesuai kebutuhan
# cp .env.example .env

# Telegram Bot (direkomendasikan)
# 1. Buat bot via @BotFather di Telegram
# 2. Copy token dari BotFather
# 3. Chat bot, kirim /start
# 4. Buka: https://api.telegram.org/bot<TOKEN>/getUpdates
# 5. Cari "chat":{"id":...} — itu chat_id kamu
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# SMTP Email (opsional, jika tidak pakai Telegram)
MANGA_SMTP_PASSWORD=your_app_password_here
MANGA_SMTP_USERNAME=your@gmail.com

# Storage
MANGA_DB_PATH=./data/manga.db
# DATABASE_URL=postgres://user:pass@host:5432/dbname  # untuk PostgreSQL

# Log level: debug | info | warn | error
MANGA_LOG_LEVEL=info

# Path ke config yaml (opsional, default: config.yaml)
# MANGA_CONFIG_PATH=/app/config.yaml
