# Telegram Bot (direkomendasikan)
# 1. Buat bot via @BotFather di Telegram
# 2. Copy token dari BotFather
# 3. Chat bot, kirim /start
# 4. Buka: https://api.telegram.org/bot<TOKEN>/getUpdates
# 5. Cari "chat":{"id":...} — itu chat_id kamu
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# SMTP Email (opsional, jika tidak pakai Telegram)
SMTP_PASSWORD=your_app_password_here
SMTP_USERNAME=your@gmail.com

# Storage & Log
DB_PATH=./data/manga.db
LOG_LEVEL=info